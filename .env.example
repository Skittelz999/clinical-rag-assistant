# App
APP_NAME=Clinical RAG Assistant
ENVIRONMENT=development

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:5173

# Database
POSTGRES_USER=clinical_app
POSTGRES_PASSWORD=change-me-local-db-password
POSTGRES_DB=clinical_rag
DATABASE_URL=postgresql+asyncpg://clinical_app:change-me-local-db-password@db:5432/clinical_rag

# AI
OPENAI_API_KEY=replace-me
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_PROVIDER=deterministic
LLM_PROVIDER=deterministic

# RAG
RAG_TOP_K=8
RAG_MIN_SCORE=0.35
MAX_UPLOAD_MB=10

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
